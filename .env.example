# CARYPASS Mobile — Variables d'environnement
# Toutes les variables EXPO_PUBLIC_* sont accessibles dans le code via process.env

# ── API Backend ──────────────────────────────────────
# URL de production (utilisée dans les builds APK/IPA)
EXPO_PUBLIC_API_URL=https://carypass-backend.zylo-platform.cloud/api

# Optionnel : URL de dev (sinon auto-détectée via Metro debuggerHost)
# EXPO_PUBLIC_DEV_API_URL=http://192.168.1.10:8000/api

# ── Analytics (optionnel) ───────────────────────────
# EXPO_PUBLIC_POSTHOG_API_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry (optionnel) ──────────────────────────────
# EXPO_PUBLIC_SENTRY_DSN=
